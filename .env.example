# LLM API key for the agent (DeepInfra, OpenRouter, OpenAI, or any
# OpenAI-compatible provider). Copy to .env and fill in.
VITE_BASHER_LLM_KEY=

# Optional: custom base URL.
#   DeepInfra:  https://api.deepinfra.com/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   OpenAI:     https://api.openai.com/v1
# VITE_BASHER_LLM_BASE_URL=https://api.deepinfra.com/v1

# Optional: override the default model.
# VITE_BASHER_LLM_MODEL=google/gemma-4-31B-it

# --- Telemetry (P2.5.2 Wave D) ---
# The opt-in telemetry recorder writes ONLY tool name + outcome +
# duration to localStorage by default. No prompt text, no DAG content,
# no node ids, no PII.
#
# To disable entirely (kills both local + remote dispatch):
# DISABLE_BASHER_TELEMETRY=true
#
# Optional: enable remote dispatch by setting an HTTPS endpoint. The
# recorder POSTs the same {kind, toolName, success, durationMs,
# timestamp, sessionId} JSON shape it stores locally.
# VITE_BASHER_TELEMETRY_URL=https://example.com/basher/telemetry
